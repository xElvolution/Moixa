# Mantle — defaults target Sepolia testnet (the demo network).
# For mainnet: MANTLE_RPC_URL=https://rpc.mantle.xyz, MANTLE_CHAIN_ID=5000,
# NEXT_PUBLIC_MANTLE_EXPLORER=https://mantlescan.xyz
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5003
NEXT_PUBLIC_MANTLE_EXPLORER=https://sepolia.mantlescan.xyz
AGENT_PRIVATE_KEY=

# Contracts (filled in automatically by the deploy script).
# Once AGENT_PRIVATE_KEY + NEXT_PUBLIC_MOIXA_BRAIN_ADDRESS are set, the agent
# records EVERY decision on-chain. No mock fallback — it fails loud if missing.
NEXT_PUBLIC_MOIXA_BRAIN_ADDRESS=
NEXT_PUBLIC_MOIXA_IDENTITY_ADDRESS=
NEXT_PUBLIC_MOIXA_EXECUTOR_ADDRESS=

# AI (GPT-4o reasoning). Without it, a real rule-based strategy is used.
OPENAI_API_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/moixa
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Agent
NEXT_PUBLIC_WS_URL=ws://localhost:3001
AGENT_WS_PORT=3001
MOIXA_LOOP_INTERVAL=300       # seconds between decision cycles
MOIXA_START_EQUITY=10000      # starting equity for the real equity curve

# DeFi APIs
DEFILLAMA_API_URL=https://api.llama.fi
COINGECKO_API_KEY=

# Bybit (AI Trading track) — public market data (price/funding/charts) needs no
# keys. Add keys + MOIXA_LIVE_TRADING=true to place real testnet orders.
# Generate testnet keys at https://testnet.bybit.com (API Management).
BYBIT_TESTNET=true
BYBIT_API_KEY=
BYBIT_API_SECRET=
MOIXA_LIVE_TRADING=false
